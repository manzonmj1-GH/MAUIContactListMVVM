<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xlmns:viewModels="clr-namespace:MauiContactList.ViewModels"
             x:Class="MauiContactList.Views.MainPage"
             Title="Contacts">
	
    <ContentPage.BindingContext>
		<viewModels:ContactsViewModel/>
    </ContentPage.BindingContext>

	<CollectionView
		ItemsSource="{Binding GroupedContacts}"
		IsGrouped="True"
		SelectionMode="Single"
		SelectionChanged="OnChoiceChanged">

		<CollectionView.GroupHeaderTemplate>
			<DataTemplate>
                <Label Text="{Binding Title}"
					   FontAttributes="Bold"
					   FontSize="20"
					   BackgroundColor="RoyalBlue">
                </Label>
			</DataTemplate>
		</CollectionView.GroupHeaderTemplate>
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <HorizontalStackLayout Padding="10" Spacing="15">
                    <Image Source="{Binding Image}"
                           HeightRequest="50"
                           WidthRequest="50"
                           Aspect="AspectFill"/>
                    <Label Text="{Binding Name}"
                           VerticalOptions="Center"
                           FontSize="16" />
                </HorizontalStackLayout>
            </DataTemplate>
        </CollectionView.ItemTemplate>
        
	</CollectionView>
	
</ContentPage>
    