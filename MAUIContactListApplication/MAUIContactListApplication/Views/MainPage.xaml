<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:MAUIContactListAppplication.ViewModels"
    x:Class="MAUIContactListApplication.Views.MainPage"
    Title="MainPage">

    <ContentPage.BindingContext>
        <viewModels:ContactsViewModel/>
    </ContentPage.BindingContext>

    <CollectionView 
        ItemsSource="{Binding GroupedContacts}"
        IsGrouped="True"
        SelectionMode="Single"
        SelectionChanged="OnSelectionChanged">

        <CollectionView.GroupHeaderTemplate>
            <DataTemplate>
                <Label 
                    Text="{Binding Title}" 
                    FontAttributes="Bold"
                    FontSize="20"
                    BackgroundColor="#F0F0F0"
                    Padding="10"/>
            </DataTemplate>
        </CollectionView.GroupHeaderTemplate>

        <CollectionView.ItemTemplate>
            <DataTemplate>
                <HorizontalStackLayout Padding="10" Spacing="15">
                    <Image 
                        Source="{Binding Image}" 
                        HeightRequest="50"
                        WidthRequest="50"
                        Aspect="AspectFill"/>
                    <Label 
                        Text="{Binding Name}" 
                        VerticalOptions="Center"
                        FontSize="16"/>
                </HorizontalStackLayout>
            </DataTemplate>
        </CollectionView.ItemTemplate>

    </CollectionView>

</ContentPage>